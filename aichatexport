                continue
            time_str = (self._fmt_iso(msg.get('created_at', ''))
                        or self._ts_to_str(msg.get('create_time')))
            msg_list.append({
                'time':    time_str,
                'type':    role.upper(),
                'content': content,
                'sender':  '我' if role in ('user', 'human') else '豆包',
            })
        return msg_list

