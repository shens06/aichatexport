        # 添加工具栏
        toolbar = tk.Frame(top)
        toolbar.pack(fill=tk.X, padx=5, pady=5)
        
        tk.Button(toolbar, text="打印", 
                 command=lambda: self.show_print_instructions()).pack(side=tk.LEFT, padx=2)
        tk.Button(toolbar, text="页面设置", 
                 command=lambda: messagebox.showinfo("提示", "请使用浏览器打印设置")).pack(side=tk.LEFT, padx=2)
        
        # 文本区域
        text_frame = tk.Frame(top)
        text_frame.pack(fill=tk.BOTH, expand=True, padx=10, pady=5)
        
        scrollbar = tk.Scrollbar(text_frame)
        scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
        
        text = tk.Text(text_frame, wrap=tk.WORD, font=('Microsoft YaHei', 10),
                      yscrollcommand=scrollbar.set)
        text.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        
        scrollbar.config(command=text.yview)
        
        # 插入内容
        text.insert(tk.END, f"对话: {self.current_conv.get('title')}\n")
        text.insert(tk.END, f"平台: {self.current_conv.get('platform')}\n")
        text.insert(tk.END, f"时间: {self.current_conv.get('time')}\n")
        text.insert(tk.END, f"导出时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
        text.insert(tk.END, "="*60 + "\n\n")
        
        for msg in self.current_conv.get('messages', []):
            text.insert(tk.END, f"[{msg.get('time')}] {msg.get('sender')}:\n")
            text.insert(tk.END, f"{msg.get('content')}\n")
            text.insert(tk.END, "-"*40 + "\n\n")
        
        text.config(state=tk.DISABLED)
    
