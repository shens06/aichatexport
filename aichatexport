    def import_files(self):
        """一键导入多个文件"""
        files = filedialog.askopenfilenames(
            title="选择聊天记录文件",
            filetypes=[("JSON文件", "*.json"), ("所有文件", "*.*")]
        )
        
        if not files:
            return
        
        self.status_var.set("正在导入...")
        self.root.update()
        
        imported = 0
        errors = []
        
        # 分批处理，避免卡顿
        batch_size = 3
        for i in range(0, len(files), batch_size):
            batch = files[i:i+batch_size]
            for file in batch:
                try:
                    # 尝试不同编码
                    data = None
                    for encoding in ['utf-8', 'utf-8-sig', 'gbk', 'gb2312']:
                        try:
                            with open(file, 'r', encoding=encoding) as f:
                                data = json.load(f)
                            break
                        except (UnicodeDecodeError, json.JSONDecodeError):
                            continue
                    
                    if data is None:
                        errors.append(f"{os.path.basename(file)}: 无法解析文件")
                        continue
                    
                    # 智能识别平台
                    platform = self.detect_platform(file, data)
                    
                    # 提取对话
                    convs = self.extract_conversations(data, platform, file)
                    self.all_conversations.extend(convs)
                    imported += len(convs)
                    
                except Exception as e:
                    errors.append(f"{os.path.basename(file)}: {str(e)}")
            
            # 更新状态
            self.status_var.set(f"已导入 {min(i+batch_size, len(files))}/{len(files)}...")
            self.root.update()
        
        self.refresh_conversation_list()
        self.update_stats()
        
        # 清空搜索缓存
        self.search_cache.clear()
        
        # 显示结果
        if errors:
            error_msg = "\n".join(errors[:5])
            if len(errors) > 5:
                error_msg += f"\n...等{len(errors)}个错误"
            messagebox.showwarning("部分成功", 
                                  f"成功导入 {imported} 个对话\n\n失败 {len(errors)} 个:\n{error_msg}")
        else:
            messagebox.showinfo("成功", f"成功导入 {imported} 个对话！")
        
        self.status_var.set(f"就绪 - 共 {len(self.all_conversations)} 个对话")
    
    def detect_platform(self, filename, data):
        """智能识别AI平台"""
        filename_lower = filename.lower()
        
        # 平台特征库
        platform_signatures = {
            'DeepSeek': {
                'keywords': ['deepseek', '深度求索'],
                'structure': lambda d: isinstance(d, list) and len(d) > 0 and 'mapping' in d[0] if isinstance(d, list) else False
            },
            'ChatGPT': {
                'keywords': ['chatgpt', 'openai', 'gpt'],
                'structure': lambda d: isinstance(d, dict) and 'conversations' in d
            },
            'Claude': {
                'keywords': ['claude', 'anthropic'],
                'structure': lambda d: isinstance(d, dict) and 'threads' in d
            },
            'Gemini': {
                'keywords': ['gemini', 'bard', 'google'],
                'structure': lambda d: isinstance(d, list) and len(d) > 0 and 'messages' in d[0]
            }
        }
        
        # 先按文件名判断
        for platform, sig in platform_signatures.items():
            if any(kw in filename_lower for kw in sig['keywords']):
                # 验证数据结构
                if sig['structure'](data):
                    return platform
        
        # 再按数据结构判断
        for platform, sig in platform_signatures.items():
            if sig['structure'](data):
                return platform
        
        return '未知平台'
    
    def extract_conversations(self, data, platform, source_file):
        """提取对话（根据不同平台）"""
        conversations = []
        file_hash = hashlib.md5(source_file.encode()).hexdigest()[:8]
        
        if platform == 'DeepSeek':
            if isinstance(data, list):
                for i, item in enumerate(data):
                    if isinstance(item, dict) and 'title' in item:
                        conv = {
                            'id': f"deepseek_{i}_{time.time()}_{file_hash}_{i}",
                            'title': item.get('title', f'对话{i+1}'),
                            'platform': 'DeepSeek',
                            'time': item.get('inserted_at', ''),
                            'messages': self.extract_deepseek_messages(item),
                            'source': source_file
                        }
                        conversations.append(conv)
        
        # 这里可以添加其他平台的解析逻辑
        
        return conversations
    
    def extract_deepseek_messages(self, conv_data):
        """提取DeepSeek消息"""
        messages = []
        
        if 'mapping' not in conv_data:
            return messages
        
        # 收集所有消息
        msg_list = []
        for node in conv_data['mapping'].values():
            if isinstance(node, dict) and node.get('message'):
                msg_data = node['message']
                fragments = msg_data.get('fragments', [])
                
                for f in fragments:
                    if isinstance(f, dict) and f.get('content'):
                        content = f['content'].strip()
                        if content:
                            msg_type = f.get('type', 'UNKNOWN')
                            time_str = msg_data.get('inserted_at', '')
                            
                            # 格式化时间
                            try:
                                if time_str:
                                    # 处理不同时间格式
                                    time_str = time_str.replace('Z', '+00:00')
                                    if 'T' in time_str:
                                        dt = datetime.fromisoformat(time_str)
                                    else:
                                        dt = datetime.strptime(time_str, '%Y-%m-%d %H:%M:%S')
                                    time_str = dt.strftime('%Y-%m-%d %H:%M:%S')
                            except:
                                pass
                            
                            msg_list.append({
                                'time': time_str,
                                'type': msg_type,
                                'content': content,
                                'sender': '我' if msg_type == 'REQUEST' else 'DeepSeek'
                            })
        
        # 按时间排序，处理空时间
        msg_list.sort(key=lambda x: x.get('time', '') or '')
        return msg_list
    
    def refresh_conversation_list(self):
        """刷新对话列表"""
        self.conv_listbox.delete(0, tk.END)
        self.filtered_indices = []
        
        for i, conv in enumerate(self.all_conversations):
            self.filtered_indices.append(i)
            self.add_to_list(conv)
    
    def add_to_list(self, conv):
        """添加到列表（带标记）"""
        title = conv.get('title', '无标题')
        platform = conv.get('platform', '未知')
        time_str = conv.get('time', '')[:10] if conv.get('time') else ''
        
        # 限制标题长度
        if len(title) > 30:
            title = title[:27] + "..."
        
        display = f"[{platform}] {title}"
        if time_str:
            display += f" ({time_str})"
        
        # 收藏标记
        if conv.get('id') in self.favorites:
            display = "⭐ " + display
        
        self.conv_listbox.insert(tk.END, display)
    
    def conversation_matches(self, conv, keyword):
        """检查对话是否匹配关键词（带缓存）"""
        conv_id = conv.get('id', '')
        cache_key = f"{conv_id}_{keyword}"
        
        if cache_key in self.search_cache:
            return self.search_cache[cache_key]
        
        # 搜索标题
        if keyword in conv.get('title', '').lower():
            self.search_cache[cache_key] = True
            return True
        
        # 搜索消息内容（限制搜索深度）
        msg_count = 0
        for msg in conv.get('messages', []):
            msg_count += 1
            if msg_count > 100:  # 只搜索前100条消息
                break
            if keyword in msg.get('content', '').lower():
                self.search_cache[cache_key] = True
                return True
        
        self.search_cache[cache_key] = False
        return False
    
    def on_search(self, *args):
        """实时搜索"""
        keyword = self.search_var.get().strip().lower()
        
        # 清空列表
        self.conv_listbox.delete(0, tk.END)
        self.filtered_indices = []
        
        if not keyword:
            # 显示全部
            for i, conv in enumerate(self.all_conversations):
                self.filtered_indices.append(i)
                self.add_to_list(conv)
            self.status_var.set(f"显示全部 {len(self.all_conversations)} 个对话")
            return
        
        # 搜索匹配的对话
        matches = 0
        for i, conv in enumerate(self.all_conversations):
            if self.conversation_matches(conv, keyword):
                self.filtered_indices.append(i)
                self.add_to_list(conv)
                matches += 1
            
            # 每100个对话更新一次状态（用update_idletasks避免处理点击等事件）
            if i % 100 == 0:
                self.status_var.set(f"搜索中... {i}/{len(self.all_conversations)}")
                self.root.update_idletasks()
        
        # 记录搜索历史
        if keyword not in self.search_history:
            self.search_history.append(keyword)
            if len(self.search_history) > 10:
                self.search_history.pop(0)
        
        self.status_var.set(f"找到 {matches} 个匹配的对话")
    
    def apply_filter(self, event=None):
        """应用筛选"""
        filter_by = self.filter_var.get()
        keyword = self.search_var.get().strip().lower()
        
        # 清空列表
        self.conv_listbox.delete(0, tk.END)
        self.filtered_indices = []
        
        now = datetime.now()
        today = date.today()
        matches = 0
        
        for i, conv in enumerate(self.all_conversations):
            # 先检查搜索关键词
            if keyword and not self.conversation_matches(conv, keyword):
                continue
            
            # 再检查时间筛选
            conv_time = conv.get('time', '')
            include = False
            
            if filter_by == "全部":
                include = True
            elif filter_by == "收藏夹":
                include = conv.get('id') in self.favorites
            elif conv_time:
                try:
                    # 处理不同时间格式
                    conv_time = conv_time.replace('Z', '+00:00')
                    if 'T' in conv_time:
                        dt = datetime.fromisoformat(conv_time)
                    elif ' ' in conv_time:
                        dt = datetime.strptime(conv_time[:10], '%Y-%m-%d')
                    else:
                        dt = datetime.min
                    
                    if filter_by == "今天":
                        include = dt.date() == today
                    elif filter_by == "本周":
                        include = (now - dt).days <= 7
                    elif filter_by == "本月":
                        include = dt.month == now.month and dt.year == now.year
                except:
                    include = False
            
            if include:
                self.filtered_indices.append(i)
                self.add_to_list(conv)
                matches += 1
        
        self.status_var.set(f"筛选后显示 {matches} 个对话")
    
    def on_select_conversation(self, event):
        """选择对话后显示详情"""
        selection = self.conv_listbox.curselection()
        if not selection:
            return
        
        list_idx = selection[0]
        if list_idx >= len(self.filtered_indices):
            return
        
        # 获取原始对话索引
        conv_idx = self.filtered_indices[list_idx]
        if conv_idx >= len(self.all_conversations):
            return
        
        self.current_conv = self.all_conversations[conv_idx]
        
        # 更新标题
        self.conv_title.config(text=self.current_conv.get('title', '无标题'))
        
        # 更新收藏按钮
        conv_id = self.current_conv.get('id')
        if conv_id and conv_id in self.favorites:
            self.fav_btn.config(text="★ 已收藏")
        else:
            self.fav_btn.config(text="☆ 收藏")
        
        # 清空并填充消息
        self.msg_text.config(state=tk.NORMAL)
        self.msg_text.delete(1.0, tk.END)

        messages = self.current_conv.get('messages', [])
        for msg in messages:
            self.insert_message(msg)

        self.msg_text.config(state=tk.DISABLED)
        self.msg_text.see(tk.END)

        # 更新统计
        self.update_stats()
    
    def insert_message(self, msg):
        """插入消息到文本框"""
        sender = msg.get('sender', 'AI')
        time_str = msg.get('time', '')
        content = msg.get('content', '')

        if len(content) > 10000:
            content = content[:10000] + "...\n\n[消息过长，已截断]"

        if time_str:
            self.msg_text.insert(tk.END, f"{time_str}\n", 'time')

        tag = 'sender_me' if sender == '我' else 'sender_ai'
        self.msg_text.insert(tk.END, f"{sender}:\n", tag)
        self.msg_text.insert(tk.END, f"{content}\n")
        self.msg_text.insert(tk.END, "─" * 40 + "\n\n", 'divider')
    
    def toggle_favorite(self):
        """切换收藏状态"""
        if not self.current_conv:
            messagebox.showwarning("提示", "请先选择一个对话")
            return
        
        # 确保有ID
        if 'id' not in self.current_conv or not self.current_conv['id']:
            self.current_conv['id'] = f"temp_{time.time()}_{hash(str(self.current_conv))}"
        
        conv_id = self.current_conv['id']
        
        if conv_id in self.favorites:
            self.favorites.remove(conv_id)
            self.fav_btn.config(text="☆ 收藏")
            self.status_var.set("已取消收藏")
        else:
            self.favorites.add(conv_id)
            self.fav_btn.config(text="★ 已收藏")
            self.status_var.set("已添加到收藏")
        
        self.update_stats()
        self.refresh_conversation_list()
    
    def update_stats(self):
        """更新统计信息"""
        total_convs = len(self.all_conversations)
        total_msgs = sum(len(c.get('messages', [])) for c in self.all_conversations)
        fav_count = len(self.favorites)
        
        self.stats_text.config(
            text=f"📊 统计\n总对话: {total_convs}\n总消息: {total_msgs}\n收藏: {fav_count}"
        )
    
    def export_txt(self):
        """导出当前对话"""
        if not self.current_conv:
            messagebox.showwarning("提示", "请先选择一个对话")
            return
        
        # 生成安全的文件名
        title = self.current_conv.get('title', '对话')
        safe_title = "".join(c for c in title if c.isalnum() or c in ' -_（）').strip()
        if not safe_title:
            safe_title = "对话"
        
        # 添加时间戳避免重名
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        safe_title = f"{safe_title}_{timestamp}"
        
        filename = filedialog.asksaveasfilename(
            defaultextension=".txt",
            filetypes=[("文本文件", "*.txt")],
            initialfile=f"{safe_title}.txt"
        )
        
        if not filename:
            return
        
        try:
            with open(filename, 'w', encoding='utf-8') as f:
                f.write(f"对话: {self.current_conv.get('title')}\n")
                f.write(f"平台: {self.current_conv.get('platform')}\n")
                f.write(f"时间: {self.current_conv.get('time')}\n")
                f.write(f"导出时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
                f.write("="*50 + "\n\n")
                
                for msg in self.current_conv.get('messages', []):
                    f.write(f"[{msg.get('time')}] {msg.get('sender')}:\n")
                    f.write(f"{msg.get('content')}\n")
                    f.write("-"*30 + "\n\n")
            
            self.status_var.set(f"已导出到: {os.path.basename(filename)}")
            
            # 询问是否打开文件
            if messagebox.askyesno("成功", f"已导出到:\n{filename}\n\n是否打开文件所在文件夹？"):
                os.startfile(os.path.dirname(filename))
                
        except Exception as e:
            messagebox.showerror("错误", f"导出失败: {str(e)}")
    
    def generate_summary(self):
        """生成摘要"""
        if not self.current_conv:
            messagebox.showwarning("提示", "请先选择一个对话")
            return
        
        messages = self.current_conv.get('messages', [])
        if not messages:
            messagebox.showinfo("提示", "该对话没有消息")
            return
        
        # 统计
        my_msgs = [m for m in messages if m.get('sender') == '我']
        ai_msgs = [m for m in messages if m.get('sender') != '我']
        
        # 计算总字数
        total_chars = sum(len(m.get('content', '')) for m in messages)
        
        # 计算平均消息长度
        avg_len = total_chars // len(messages) if messages else 0
        
        # 获取时间范围
        times = [m.get('time', '') for m in messages if m.get('time')]
        start_time = min(times) if times else '未知'
        end_time = max(times) if times else '未知'
        
        summary = f"""
📊 对话摘要
━━━━━━━━━━━━━━━━━━
标题: {self.current_conv.get('title')}
平台: {self.current_conv.get('platform')}
时间范围: {start_time} 至 {end_time}

📝 统计信息
• 总消息: {len(messages)} 条
• 我的消息: {len(my_msgs)} 条
• AI消息: {len(ai_msgs)} 条
• 总字数: {total_chars} 字
• 平均长度: {avg_len} 字/条

💬 对话比例
• 我: {len(my_msgs)/len(messages)*100:.1f}%
• AI: {len(ai_msgs)/len(messages)*100:.1f}%

📌 最近5条消息:
"""
        
        for i, msg in enumerate(messages[-5:]):
            content = msg.get('content', '')[:50]
            if len(msg.get('content', '')) > 50:
                content += "..."
            summary += f"{i+1}. {msg.get('sender')}: {content}\n"
        
        # 显示在新窗口
        top = tk.Toplevel(self.root)
        top.title("对话摘要")
        top.geometry("550x500")
        top.transient(self.root)
        top.grab_set()
        
        # 添加滚动条
        text_frame = tk.Frame(top)
        text_frame.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)
        
        scrollbar = tk.Scrollbar(text_frame)
        scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
        
        text = tk.Text(text_frame, wrap=tk.WORD, font=('Microsoft YaHei', 10),
                      yscrollcommand=scrollbar.set)
        text.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        
        scrollbar.config(command=text.yview)
        
        text.insert(tk.END, summary)
        text.config(state=tk.DISABLED)
        
        # 按钮框架
        btn_frame = tk.Frame(top)
        btn_frame.pack(fill=tk.X, padx=10, pady=5)
        
        tk.Button(btn_frame, text="复制摘要", 
                 command=lambda: self.copy_to_clipboard(summary)).pack(side=tk.LEFT, padx=5)
        tk.Button(btn_frame, text="关闭", command=top.destroy).pack(side=tk.RIGHT, padx=5)
    
    def copy_all(self):
        """复制全部消息"""
        if not self.current_conv:
            messagebox.showwarning("提示", "请先选择一个对话")
            return
        
        content = ""
        for msg in self.current_conv.get('messages', []):
            content += f"[{msg.get('time')}] {msg.get('sender')}:\n{msg.get('content')}\n\n"
        
        self.copy_to_clipboard(content)
        self.status_var.set("已复制到剪贴板")
        messagebox.showinfo("成功", "已复制到剪贴板")
    
    def copy_to_clipboard(self, text):
        """复制文本到剪贴板"""
        self.root.clipboard_clear()
        self.root.clipboard_append(text)
    
    def print_conversation(self):
        """打印对话"""
        if not self.current_conv:
            messagebox.showwarning("提示", "请先选择一个对话")
            return
        
        # 简单的打印预览
        top = tk.Toplevel(self.root)
