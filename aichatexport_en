    def export_all(self):
        """Export all visible conversations as a ZIP file"""
        convs = [self.all_conversations[i] for i in self.filtered_indices]
        if not convs:
            messagebox.showwarning("Notice", "No conversations to export")
            return

        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        zip_path = filedialog.asksaveasfilename(
            title="Save ZIP File",
            defaultextension=".zip",
            filetypes=[("ZIP Files", "*.zip")],
            initialfile=f"chat_export_{timestamp}.zip",
        )
        if not zip_path:
            return

        ok = 0
        errors = []
        total = len(convs)
        export_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')

        self.status_var.set(f"Exporting 0/{total}...")
        self.root.update_idletasks()

        try:
            with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zf:
                for idx, conv in enumerate(convs, 1):
                    try:
                        title = conv.get('title', 'conversation')
                        platform = conv.get('platform', 'Unknown')
                        safe_title = "".join(
                            c for c in title if c.isalnum() or c in ' -_'
                        ).strip() or "conversation"
                        entry_name = f"{idx:04d}_{platform}_{safe_title[:40]}.txt"

                        buf = io.StringIO()
                        buf.write(f"Title: {title}\n")
                        buf.write(f"Platform: {platform}\n")
                        buf.write(f"Time: {conv.get('time', '')}\n")
                        buf.write(f"Exported: {export_time}\n")
                        buf.write("=" * 50 + "\n\n")
                        for msg in conv.get('messages', []):
                            buf.write(f"[{msg.get('time', '')}] {msg.get('sender', '')}:\n")
                            buf.write(f"{msg.get('content', '')}\n")
                            buf.write("-" * 30 + "\n\n")

                        zf.writestr(entry_name, buf.getvalue().encode('utf-8'))
                        ok += 1
                    except Exception as e:
                        errors.append(f"{conv.get('title', '')}: {str(e)}")

                    if idx % 10 == 0 or idx == total:
                        self.status_var.set(f"Exporting {idx}/{total}...")
                        self.root.update_idletasks()
        except Exception as e:
            messagebox.showerror("Error", f"Failed to create ZIP: {str(e)}")
            return

        self.status_var.set(f"Ready - exported {ok}/{total} conversations")

        msg = f"Exported {ok} conversations\nSaved to: {zip_path}"
        if errors:
            msg += f"\n\nFailed {len(errors)}:\n" + "\n".join(errors[:5])
            messagebox.showwarning("Export Complete", msg)
        else:
            if messagebox.askyesno("Export Complete", msg + "\n\nOpen containing folder?"):
                folder = os.path.dirname(zip_path)
                if sys.platform == 'win32':
                    os.startfile(folder)
                elif sys.platform == 'darwin':
                    subprocess.run(['open', folder])
                else:
                    subprocess.run(['xdg-open', folder])

    def generate_summary(self):
        """Generate a summary for the current conversation"""
        if not self.current_conv:
            messagebox.showwarning("Notice", "Please select a conversation first")
            return

        messages = self.current_conv.get('messages', [])
        if not messages:
            messagebox.showinfo("Notice", "This conversation has no messages")
            return

        my_msgs = [m for m in messages if m.get('sender') == 'Me']
        ai_msgs = [m for m in messages if m.get('sender') != 'Me']

        total_chars = sum(len(m.get('content', '')) for m in messages)
        avg_len = total_chars // len(messages) if messages else 0

        times = [m.get('time', '') for m in messages if m.get('time')]
        start_time = min(times) if times else 'Unknown'
        end_time = max(times) if times else 'Unknown'

        summary = f"""
📊 Conversation Summary
━━━━━━━━━━━━━━━━━━
Title: {self.current_conv.get('title')}
Platform: {self.current_conv.get('platform')}
Time range: {start_time} to {end_time}

📝 Statistics
• Total messages: {len(messages)}
• My messages: {len(my_msgs)}
• AI messages: {len(ai_msgs)}
• Total characters: {total_chars}
• Avg length: {avg_len} chars/msg

💬 Message ratio
• Me: {len(my_msgs)/len(messages)*100:.1f}%
• AI: {len(ai_msgs)/len(messages)*100:.1f}%

📌 Last 5 messages:
"""

        for i, msg in enumerate(messages[-5:]):
            content = msg.get('content', '')[:50]
            if len(msg.get('content', '')) > 50:
                content += "..."
            summary += f"{i+1}. {msg.get('sender')}: {content}\n"

        top = tk.Toplevel(self.root)
        top.title("Conversation Summary")
        top.geometry("550x500")
        top.transient(self.root)
        top.grab_set()

        text_frame = tk.Frame(top)
        text_frame.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)

        scrollbar = tk.Scrollbar(text_frame)
        scrollbar.pack(side=tk.RIGHT, fill=tk.Y)

        text = tk.Text(text_frame, wrap=tk.WORD, font=('Segoe UI', 10),
                      yscrollcommand=scrollbar.set)
        text.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)

        scrollbar.config(command=text.yview)

        text.insert(tk.END, summary)
        text.config(state=tk.DISABLED)

        btn_frame = tk.Frame(top)
        btn_frame.pack(fill=tk.X, padx=10, pady=5)

        tk.Button(btn_frame, text="Copy Summary",
                 command=lambda: self.copy_to_clipboard(summary)).pack(side=tk.LEFT, padx=5)
        tk.Button(btn_frame, text="Close", command=top.destroy).pack(side=tk.RIGHT, padx=5)

    def copy_all(self):
        """Copy all messages to clipboard"""
        if not self.current_conv:
            messagebox.showwarning("Notice", "Please select a conversation first")
            return

        content = ""
        for msg in self.current_conv.get('messages', []):
            content += f"[{msg.get('time')}] {msg.get('sender')}:\n{msg.get('content')}\n\n"

        self.copy_to_clipboard(content)
        self.status_var.set("Copied to clipboard")
        messagebox.showinfo("Success", "Copied to clipboard")

    def copy_to_clipboard(self, text):
        """Copy text to clipboard"""
        self.root.clipboard_clear()
        self.root.clipboard_append(text)

