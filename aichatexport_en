            msg_list.append({
                'time':    self._fmt_iso(msg.get('create_time', msg.get('timestamp', ''))),
                'type':    role.upper(),
                'content': content,
                'sender':  'Me' if role in ('user', 'human') else 'Gemini',
            })
        msg_list.sort(key=lambda x: x.get('time', '') or '')
        return msg_list

    # ── Doubao ────────────────────────────────────────────────

